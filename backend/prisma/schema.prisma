

datasource db {
  provider = "postgresql"
}
generator client {
    provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  xp        Int      @default(0)
  level     Int      @default(1)
  createdAt DateTime @default(now())
}